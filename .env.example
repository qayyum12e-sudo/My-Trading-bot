# Bybit API Keys
# Demo (paper trading): create at https://testnet.bybit.com
# Live: create at https://bybit.com -> API Management
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# Set to true for demo/paper trading, false for live
TESTNET=true

# Optional: Supabase for persistent trade history
SUPABASE_URL=
SUPABASE_KEY=

# Port (Railway sets this automatically)
PORT=5000
